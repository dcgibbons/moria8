{
  "platform": "cx16",
  "machine": {
    "cpu": "65C02",
    "ram_kb": 512
  },
  "display": {
    "hardware": "vera",
    "columns": 80,
    "rows": 30,
    "viewport": {
      "x": 1,
      "y": 2,
      "width": 78,
      "height": 22
    },
    "text_vram": "vera:$1b000",
    "io_base": "$9f20"
  },
  "storage": {
    "bus": "cmdr_dos",
    "program_media": "prg",
    "save_media": "native-overlay-record",
    "default_program_device": null,
    "default_save_device": 8,
    "compatible_modes": ["x16emu-prg"]
  },
  "memory": {
    "banking": "$0000/$0001",
    "fixed_ram_base": "$0000",
    "fixed_ram_end": "$9eff",
    "io_hole_base": "$9f00",
    "io_hole_end": "$9fff",
    "banked_ram_base": "$a000",
    "banked_ram_end": "$bfff",
    "bank_count": 64,
    "fixed_regions": {
      "resident_code": "$0801-$67ff",
      "live_map": "$6800-$9b0b",
      "floor_items": "$9c00-$9cff",
      "creature_scratch": "$9d00-$9dff",
      "huffman_decode": "$9e00-$9eff",
      "vera_io": "$9f00-$9fff"
    },
    "bank_classes": {
      "0": "default/system visible bank; not persistent cache",
      "1-3": "transient scratch/loader/test banks",
      "4-7": "persistent monster tier cache",
      "8": "persistent DUNGEON.GEN executable module",
      "9-10": "persistent item catalog family",
      "11": "title-art source/staging bank",
      "12": "preloaded overlay payload: X16.START",
      "13": "preloaded overlay payload: X16.TOWN",
      "14": "preloaded overlay payload: X16.DEATH",
      "15": "preloaded overlay payload: X16.GEN",
      "16": "preloaded overlay payload: X16.HELP",
      "17": "preloaded overlay payload: X16.UI",
      "18": "preloaded overlay payload: X16.ITEMS",
      "19": "preloaded overlay payload: X16.SAVE",
      "20": "preloaded overlay payload: X16.DISARM",
      "21-31": "unallocated persistent code-overlay expansion cache",
      "32-47": "unallocated persistent immutable-data/string cache",
      "48-63": "unallocated transient save/generation/work cache"
    }
  },
  "capabilities": {
    "resident_overlay_cache": true,
    "vera_text": true,
    "vera_psg": true,
    "ym2151": true,
    "cmdr_dos_storage": true,
    "shared_storage_hal": true
  }
}
